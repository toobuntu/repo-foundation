root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# Shell scripts: two-space indent (the toobuntu house style). shfmt reads these
# keys directly when run without explicit -i/-ci/-sr flags. Homebrew-aligned
# repos (homebrew-cask-tools, babble) do NOT use this file — they defer to
# `brew style`, which enforces four-space and Homebrew's other rules; those
# repos carry Homebrew/brew's .editorconfig verbatim instead.
[*.{sh,bash,ksh}]
indent_style = space
indent_size = 2
space_redirects = true

# Git hooks and run-parts plugins carry no file extension, so match by name.
[{**/pre-commit,**/pre-push,**/pre-commit.d/*}]
indent_style = space
indent_size = 2
space_redirects = true

[Makefile]
indent_style = tab

# Markdown line breaks can be two trailing spaces; do not strip them.
[*.md]
trim_trailing_whitespace = false

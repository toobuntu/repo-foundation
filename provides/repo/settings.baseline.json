{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "HOMEBREW_NO_ANALYTICS": "1"
  },
  "permissions": {
    "allow": [
      "Bash(git status:*)",
      "Bash(git log:*)",
      "Bash(git diff:*)",
      "Bash(git show:*)",
      "Bash(git rev-parse:*)",
      "Bash(git ls-files:*)",
      "Bash(git ls-tree:*)",
      "Bash(git config --get:*)",
      "Bash(git remote -v)",
      "Bash(git remote get-url:*)",
      "Bash(git branch)",
      "Bash(git branch --show-current)",
      "Bash(git branch --list)",
      "Bash(git branch --list:*)",
      "Bash(git branch -v)",
      "Bash(git branch -vv)",
      "Bash(git branch -a)",
      "Bash(git branch -r)",
      "Bash(git tag)",
      "Bash(git tag --list)",
      "Bash(git tag -l:*)",
      "Bash(git fetch)",
      "Bash(git fetch:*)",
      "Bash(git worktree list)",

      "Bash(gh pr view:*)",
      "Bash(gh pr list:*)",
      "Bash(gh pr checks:*)",
      "Bash(gh pr diff:*)",
      "Bash(gh issue view:*)",
      "Bash(gh issue list:*)",
      "Bash(gh repo view:*)",
      "Bash(gh run view:*)",
      "Bash(gh run list:*)",
      "Bash(gh release list:*)",
      "Bash(gh release view:*)",
      "Bash(gh api /repos/:*)",
      "Bash(gh api /users/:*)",
      "Bash(gh api -X GET:*)",
      "Bash(gh auth status)",

      "Bash(reuse lint)",
      "Bash(reuse lint:*)",
      "Bash(reuse download:*)",
      "Bash(actionlint:*)",
      "Bash(zizmor:*)",
      "Bash(shellcheck:*)",
      "Bash(shfmt --diff:*)",
      "Bash(checkmake:*)"
    ],
    "ask": [
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git tag -a:*)",
      "Bash(git tag -d:*)",
      "Bash(git checkout:*)",
      "Bash(git switch:*)",
      "Bash(git stash:*)",
      "Bash(git restore:*)",
      "Bash(git reset)",
      "Bash(git reset --soft:*)",
      "Bash(git reset --mixed:*)",
      "Bash(git reset HEAD)",
      "Bash(git reset HEAD:*)",
      "Bash(git rm:*)",
      "Bash(git mv:*)",
      "Bash(git rebase:*)",
      "Bash(git cherry-pick:*)",
      "Bash(git revert:*)",
      "Bash(git merge:*)",
      "Bash(git pull:*)",
      "Bash(git branch -d:*)",
      "Bash(git branch -m:*)",
      "Bash(git branch --move:*)",
      "Bash(git branch --delete:*)",
      "Bash(git worktree add:*)",
      "Bash(git worktree remove:*)",
      "Bash(git worktree prune)",

      "Bash(gh pr comment:*)",
      "Bash(gh pr edit:*)",
      "Bash(gh pr create:*)",
      "Bash(gh pr review:*)",
      "Bash(gh pr ready:*)",
      "Bash(gh issue comment:*)",
      "Bash(gh issue create:*)",
      "Bash(gh issue edit:*)",
      "Bash(gh release create:*)",

      "Bash(reuse annotate:*)",
      "Bash(bundle install)",
      "Bash(curl:*)"
    ],
    "deny": [
      "Bash(git push)",
      "Bash(git push:*)",
      "Bash(git push --force)",
      "Bash(git push --force-with-lease:*)",
      "Bash(git push --force-with-lease)",
      "Bash(git reset --hard:*)",
      "Bash(git reset --hard)",
      "Bash(git reset --keep:*)",
      "Bash(git branch -D:*)",
      "Bash(git branch --delete --force:*)",
      "Bash(git clean:*)",
      "Bash(git filter-branch:*)",
      "Bash(git filter-repo:*)",
      "Bash(git update-ref:*)",
      "Bash(git replace:*)",
      "Bash(git reflog expire:*)",
      "Bash(git reflog delete:*)",
      "Bash(git gc --prune:*)",
      "Bash(git tag -f:*)",
      "Bash(git tag --force:*)",
      "Bash(git tag -d origin/:*)",
      "Bash(git remote add:*)",
      "Bash(git remote remove:*)",
      "Bash(git remote rm:*)",
      "Bash(git remote rename:*)",
      "Bash(git remote set-url:*)",
      "Bash(git config --unset:*)",
      "Bash(git config --unset-all:*)",
      "Bash(git config --remove-section:*)",
      "Bash(git config --global:*)",

      "Bash(gh pr merge:*)",
      "Bash(gh pr close:*)",
      "Bash(gh pr delete:*)",
      "Bash(gh repo delete:*)",
      "Bash(gh repo archive:*)",
      "Bash(gh repo edit:*)",
      "Bash(gh release delete:*)",
      "Bash(gh release upload:*)",
      "Bash(gh secret set:*)",
      "Bash(gh secret delete:*)",
      "Bash(gh ruleset delete:*)",
      "Bash(gh api -X DELETE:*)",
      "Bash(gh api -X PUT:*)",
      "Bash(gh api -X POST:*)",
      "Bash(gh api -X PATCH:*)",
      "Bash(gh api --method DELETE:*)",
      "Bash(gh api --method PUT:*)",
      "Bash(gh api --method POST:*)",
      "Bash(gh api --method PATCH:*)",
      "Bash(gh auth login:*)",
      "Bash(gh auth logout:*)",
      "Bash(gh auth refresh:*)",

      "Bash(rm -rf:*)",
      "Bash(rm -fr:*)",
      "Bash(rm -Rf:*)",
      "Bash(rm -fR:*)",
      "Bash(rm -rf .)",
      "Bash(rm -rf /)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf $HOME)",
      "Bash(sudo rm:*)",
      "Bash(sudo make:*)",
      "Bash(sudo:*)",

      "Bash(log erase:*)",
      "Bash(pmset -a:*)",
      "Bash(pmset -b:*)",
      "Bash(pmset -c:*)",
      "Bash(pmset -u:*)",
      "Bash(pmset schedule:*)",
      "Bash(pmset repeat:*)",
      "Bash(pmset sleepnow)",
      "Bash(pmset displaysleepnow)",
      "Bash(defaults write:*)",
      "Bash(defaults delete:*)",
      "Bash(nvram:*)",
      "Bash(csrutil:*)",
      "Bash(kmutil:*)",
      "Bash(kextload:*)",
      "Bash(kextunload:*)",
      "Bash(dscl . -create:*)",
      "Bash(dscl . -delete:*)",
      "Bash(dscl . -change:*)",
      "Bash(dscl . -append:*)",
      "Bash(dseditgroup:*)",
      "Bash(pwpolicy:*)",
      "Bash(launchctl reboot:*)",
      "Bash(launchctl unload:*)",
      "Bash(shutdown:*)",
      "Bash(reboot:*)",
      "Bash(halt:*)",
      "Bash(killall -9:*)",

      "Bash(brew install:*)",
      "Bash(brew uninstall:*)",
      "Bash(brew remove:*)",
      "Bash(brew upgrade:*)",
      "Bash(brew cleanup:*)",
      "Bash(npm install:*)",
      "Bash(npm uninstall:*)",
      "Bash(pip install:*)",
      "Bash(pip uninstall:*)",
      "Bash(gem install:*)",
      "Bash(gem uninstall:*)",
      "Bash(curl -X DELETE:*)",
      "Bash(curl --request DELETE:*)",
      "Bash(curl -X PUT:*)",
      "Bash(curl --request PUT:*)",
      "Bash(curl -X POST:*)",
      "Bash(curl --request POST:*)",
      "Bash(curl -X PATCH:*)",
      "Bash(curl --request PATCH:*)",
      "Bash(curl:* | sh)",
      "Bash(curl:* | bash)",
      "Bash(curl:* | zsh)",
      "Bash(wget:*)",

      "Read(./.env)",
      "Read(./.env.*)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/**)",
      "Read(~/.config/gh/**)",
      "Read(~/.gnupg/**)",
      "Read(~/Library/Keychains/**)",
      "Read(~/.config/Anthropic/**)",
      "Read(~/.claude.json)"
    ],
    "disableBypassPermissionsMode": "disable"
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "excludedCommands": [
      "git commit *",
      "git -c commit.gpgsign=false commit *",
      "git pull *",
      "git fetch *",
      "git checkout *",
      "git switch *",
      "git rebase *",
      "git merge *",
      "git stash *",
      "git restore *",
      "git rm *",
      "git mv *",
      "git revert *",
      "git cherry-pick *",
      "git worktree *",
      "gh pr *",
      "gh issue *",
      "gh release *",
      "gh api *",
      "reuse annotate *",
      "reuse download *",
      "zizmor *",
      "bundle install"
    ],
    "filesystem": {
      "denyRead": [
        "~/.ssh",
        "~/.aws",
        "~/.gnupg",
        "~/.config/gh",
        "~/.claude.json",
        "~/Library/Keychains"
      ]
    },
    "network": {
      "allowedDomains": [
        "api.github.com",
        "github.com",
        "objects.githubusercontent.com",
        "raw.githubusercontent.com",
        "codeload.github.com",
        "rubygems.org",
        "index.rubygems.org",
        "api.rubygems.org",
        "formulae.brew.sh",
        "registry.npmjs.org",
        "code.claude.com",
        "docs.claude.com",
        "platform.claude.com",
        "anthropic.com",
        "*.anthropic.com",
        "api.anthropic.com",
        "claude.com",
        "*.claude.com"
      ]
    }
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "if command -v jq >/dev/null 2>&1; then fp=$(jq -r '.tool_input.file_path // empty' 2>/dev/null || true); fi; if [ -z \"$fp\" ]; then fp=\"${CLAUDE_PROJECT_DIR:-$PWD}/\"; fi; case \"$fp\" in /*) ;; *) fp=\"${CLAUDE_PROJECT_DIR:-$PWD}/$fp\" ;; esac; case \"$fp\" in \"${CLAUDE_PROJECT_DIR:-$PWD}\"/*) if [ \"$(git -C \"${CLAUDE_PROJECT_DIR:-.}\" branch --show-current)\" = \"main\" ]; then echo 'Direct edits to main are not allowed. Create a feature branch (git switch -c feature/<topic>) before editing.' >&2; exit 2; fi ;; esac",
            "timeout": 5
          }
        ]
      }
    ]
  }
}

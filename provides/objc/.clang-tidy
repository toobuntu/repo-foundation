# Clang-tidy checks for Objective-C / C code.
# Run: make tidy  (the Makefile `tidy` target holds the exact invocation;
# clang-tidy is from Homebrew llvm on macOS, not the Xcode toolchain).

Checks: >
  -*,
  bugprone-*,
  clang-analyzer-*,
  misc-redundant-expression,
  readability-duplicate-include,
  readability-misleading-indentation,
  -bugprone-easily-swappable-parameters,
  -bugprone-assignment-in-if-condition,
  -clang-analyzer-security.insecureAPI.DeprecatedOrUnsafeBufferHandling

# Private API extern: CGSConfigureDisplayEnabled is intentionally unresolvable.
# Deprecated API: CGDisplayIOServicePort has no replacement; usage is guarded.
WarningsAsErrors: ''

HeaderFilterRegex: 'src/.*'
